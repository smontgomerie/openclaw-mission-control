## Bootstrap steps (run in order)
1) Ensure required tools are installed:

```bash
for tool in curl jq; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "Missing required tool: $tool" >&2
    echo "Install examples:" >&2
    echo "  Ubuntu/Debian: sudo apt-get update && sudo apt-get install -y curl jq" >&2
    echo "  RHEL/CentOS:   sudo dnf install -y curl jq" >&2
    echo "  macOS (brew):  brew install curl jq" >&2
    exit 1
  fi
done
```

2) Verify API reachability:

```bash
curl -fsS "{{ base_url }}/healthz" >/dev/null
```

3) Ensure required files exist:
- `AGENTS.md`, `IDENTITY.md`, `SOUL.md`, `USER.md`, `TOOLS.md`, `MEMORY.md`, `HEARTBEAT.md`, `BOOTSTRAP.md`

4) Create `memory/` if missing.

5) Ensure today's daily file exists: `memory/YYYY-MM-DD.md`.

6) Create stable Mission Control wrappers and prefer allowlisting them instead of generic `curl` or inline shell:

```bash
mkdir -p .mission-control
cat > .mission-control/heartbeat.sh <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

workspace_root="${WORKSPACE_ROOT:-$PWD}"
tools_file="${workspace_root}/TOOLS.md"
if [[ ! -f "$tools_file" ]]; then
  tools_file="TOOLS.md"
fi

read_tools_value() {
  local key="$1"
  awk -v key="$key" '
    {
      line = $0
      sub(/^[[:space:]]*-[[:space:]]*/, "", line)
      gsub(/^`|`$/, "", line)
      if (line ~ ("^" key "=")) {
        sub("^" key "=", "", line)
        print line
        exit
      }
    }
  ' "$tools_file"
}

base_url="${BASE_URL:-$(read_tools_value BASE_URL)}"
auth_token="${AUTH_TOKEN:-$(read_tools_value AUTH_TOKEN)}"

if [[ "${1:-}" == "online" ]]; then
  if [[ $# -ne 3 ]]; then
    echo "usage: $0 online <agent_name> <board_id>" >&2
    exit 2
  fi

  agent_name="$2"
  board_id="$3"
else
  if [[ $# -ne 0 ]]; then
    echo "usage: $0 [online <agent_name> <board_id>]" >&2
    exit 2
  fi
  agent_name="${AGENT_NAME:-$(read_tools_value AGENT_NAME)}"
  board_id="${BOARD_ID:-$(read_tools_value BOARD_ID)}"
fi

if [[ -z "$base_url" || -z "$auth_token" ]]; then
  echo "Error: missing BASE_URL or AUTH_TOKEN in TOOLS.md" >&2
  exit 1
fi

exec curl -fsS -X POST "${base_url}/api/v1/agent/heartbeat" \
  -H "X-Agent-Token: ${auth_token}"
EOF
chmod 700 .mission-control/heartbeat.sh

cat > .mission-control/preflight.sh <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

workspace_root="${WORKSPACE_ROOT:-$PWD}"
state_file="${workspace_root}/.state/gateway_status"
mkdir -p "$(dirname "$state_file")"

base_url="{{ base_url }}"
auth_token="{{ auth_token }}"
board_id="{{ board_id }}"

if [[ -f "$state_file" ]]; then
  # shellcheck disable=SC1090
  . "$state_file"
else
  last_status="unknown"
  last_alert_time=0
fi

current_status="unknown"
if curl -fsS "${base_url}/healthz" >/dev/null \
  && curl -fsS -H "X-Agent-Token: ${auth_token}" "${base_url}/api/v1/agent/boards" >/dev/null \
  && curl -fsS -H "X-Agent-Token: ${auth_token}" "${base_url}/api/v1/agent/boards/${board_id}/tasks" >/dev/null; then
  current_status="up"
else
  current_status="down"
fi

now="$(date +%s)"
message=""

if [[ "$current_status" == "up" ]]; then
  if [[ "${last_status}" == "down" ]]; then
    message="API gateway is now up."
    last_status="up"
    last_alert_time="$now"
  fi
else
  if [[ "${last_status}" == "up" ]]; then
    message="API gateway is now down."
    last_status="down"
    last_alert_time="$now"
  elif (( now - last_alert_time > 1800 )); then
    message="API gateway is still down. Already escalated to @lead; waiting for gateway to be restored."
    last_alert_time="$now"
  fi
fi

if [[ -z "$message" ]]; then
  message="HEARTBEAT_OK"
fi

{
  printf 'last_status="%s"\n' "${last_status}"
  printf 'last_alert_time=%s\n' "${last_alert_time}"
} > "$state_file"

echo "$message"
EOF
chmod 700 .mission-control/preflight.sh
```

